# ===========================================
# WearStore Environment Configuration
# ===========================================

# Node Environment
NODE_ENV=development

# ===========================================
# Database (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/wearstore

# ===========================================
# JWT Authentication
# ===========================================
JWT_ACCESS_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-32-characters-long

# ===========================================
# API Server
# ===========================================
API_PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# ===========================================
# Frontend (Vite)
# ===========================================
VITE_API_URL=http://localhost:3001

# ===========================================
# LiqPay Payment Gateway (Optional)
# ===========================================
# LIQPAY_PUBLIC_KEY=your-liqpay-public-key
# LIQPAY_PRIVATE_KEY=your-liqpay-private-key

# ===========================================
# SMTP Email (Optional)
# ===========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ===========================================
# S3 Storage (Optional)
# ===========================================
# S3_ENDPOINT=https://your-s3-endpoint.com
# S3_ACCESS_KEY=your-s3-access-key
# S3_SECRET_KEY=your-s3-secret-key
# S3_BUCKET=wearstore-images
# S3_PUBLIC_URL=https://your-cdn-url.com
